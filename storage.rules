rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Single-segment audio files (e.g. music/12345_song.mp3) — public preview
    match /music/{file} {
      allow read: if true;
      allow write: if isAdminAuth();
    }

    // Cover images — public
    match /music/images/{file=**} {
      allow read: if true;
      allow write: if isAdminAuth();
    }

    // Rights PDFs — NOT publicly readable by regular users. Admins can read
    // (needed for getDownloadURL after upload). User downloads go via signed URLs.
    match /music/pdfs/{file=**} {
      allow read: if isAdminAuth();
      allow write: if isAdminAuth();
    }

    // Purchased content — each user can read only their own files.
    // Writes are server-only (Admin SDK).
    match /purchases/{userId}/{file=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAdminAuth() {
      return request.auth != null && request.auth.token.email != null && (
        request.auth.token.email == 'thelegendofhendo@gmail.com' ||
        request.auth.token.email == 'nikodola@gmail.com'
      );
    }
  }
}
